{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": "../data/books.db"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/covers/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/(.*)/others",
      "destination": "/static/other.html"
    },
    {
      "source": "/others",
      "destination": "/static/other.html"
    },
    {
      "source": "/",
      "destination": "/static/index.html"
    }
  ]
}
